      {
        "name": "country",
        "type": "TEXT",
        "nullable": true,
        "comment": "ISO alpha-2"
      },
      {
        "name": "zip_code",
        "type": "TEXT",
        "nullable": true,
        "comment": "format-validated upstream"
      },
      {
        "name": "gender",
        "type": "TEXT",
        "nullable": true,
        "comment": "'Male','Female','Other','Prefer not to say'",
        "suggested_values": [
          "Male",
          "Female",
          "Other",
          "Prefer not to say"
        ]
      },
      {
        "name": "time_zone",
        "type": "TEXT",
        "nullable": true
      },
      {
        "name": "password_hash",
        "type": "TEXT",
        "nullable": true,
        "comment": "for fans using email/password (nullable)"
      },
      {
        "name": "passkey_public_key",
        "type": "JSONB",
        "nullable": true,
        "comment": "WebAuthn credential (nullable)"
